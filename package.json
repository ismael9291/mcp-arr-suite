{
  "name": "mcp-arr-suite",
  "version": "1.3.0",
  "description": "MCP server for the *arr media management suite — Sonarr, Radarr, Lidarr, Prowlarr",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "mcp-arr-suite": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results.xml",
    "test:live": "vitest run --config vitest.live.config.ts"
  },
  "keywords": [
    "mcp",
    "sonarr",
    "radarr",
    "lidarr",
    "prowlarr",
    "media",
    "model-context-protocol",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.29",
    "@vitest/coverage-v8": "^4.1.2",
    "msw": "^2.12.14",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismael9291/mcp-arr-suite.git"
  }
}
